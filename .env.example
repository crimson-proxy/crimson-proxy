# Crimson's Proxy backend env vars.
# Copy to .env and fill in. Anything blank falls back to the defaults in
# src/server/lib/config.ts.
#
# ─── SYNC RULE — read before editing ─────────────────────────────────
# Any change to a value here MUST also be pushed to ALL FOUR stores:
#   1. .env (this file).
#   2. .dev.vars (for local `npm run dev:cf` — gitignored, mirrors .env).
#   3. Vercel: Settings → Environment Variables (or `vercel env add NAME production --force`).
#   4. Cloudflare: `wrangler secret put NAME` (for secrets) or `[vars]`
#      in wrangler.toml + commit (for non-secrets).
# Drift between any of these is the #1 source of "works on my machine,
# broken in prod" outages. If you rotate a secret, rotate it in all four.

# ─── Server ───────────────────────────────────────────────────────────
PORT=3000

# ─── Admin panel ─────────────────────────────────────────────────────
# HMAC secret for signing admin JWTs. Rotate this to invalidate all sessions.
ADMIN_SIGNING_SECRET=

# ─── Database (Aiven Postgres) ───────────────────────────────────────
# Any Postgres host works: Aiven, Supabase direct, Neon, RDS, self-hosted.
# Switching providers later = change this one value (no code edits).
# Run `npm run migrate` after configuring to create the schema.
DATABASE_URL=

# ─── Discord integration ─────────────────────────────────────────────
# All values come from Discord Developer Portal > Your App.
#
# DB-OVERRIDABLE: DISCORD_SERVER_ID, DISCORD_REQUIRED_ROLE_ID,
# DISCORD_ADMIN_ROLE_IDS and DISCORD_STAFF_CHANNEL_ID are read from the
# app_config table at runtime (DB value wins). The values below are the
# BOOTSTRAP FALLBACK so dashboard access works on a fresh deploy before
# the DB is seeded. Secrets (public key, bot token, client secret) stay
# env-only.
DISCORD_APP_ID=
# From General Information > Public Key.
DISCORD_PUBLIC_KEY=
# From Bot > Reset Token.
DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=
DISCORD_REQUIRED_ROLE_ID=
# Comma-separated role IDs that grant admin access (moderator, admin, owner).
DISCORD_ADMIN_ROLE_IDS=
# From OAuth2 > Client Secret > Reset Secret.
# Required for the /login Discord authentication flow.
DISCORD_CLIENT_SECRET=

# Channel ID where the bot posts staff alerts (e.g. when the AI provider
# pool drops to 2 or fewer available accounts). Right-click the channel
# in Discord with Developer Mode on -> Copy Channel ID. Optional: if
# empty, alerts are silently skipped. (DB-overridable — see note above.)
DISCORD_STAFF_CHANNEL_ID=
